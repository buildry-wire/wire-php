{
  "name": "buildry-wire/wire-php",
  "description": "Official PHP SDK for the Wire payment API",
  "type": "library",
  "license": "MIT",
  "homepage": "https://wire.mn",
  "support": {
    "docs": "https://docs.wire.mn",
    "source": "https://github.com/buildry-wire/wire-php"
  },
  "authors": [
    { "name": "Buildry" }
  ],
  "require": {
    "php": ">=8.1",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "BuildryWire\\Wire\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "BuildryWire\\Wire\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable"
}
